PROFILE_NAME=gentoo-6.12-lts
KERNEL_SOURCE_KIND=tarball

# Gentoo currently carries 6.12 on ppc as well. Fill this in with the exact
# tarball you choose to align with the matching genpatches release you stage.
KERNEL_TARBALL_URL=https://cdn.kernel.org/pub/linux/kernel/v6.x/linux-6.12.76.tar.xz
KERNEL_TARBALL_NAME=linux-6.12.76.tar.xz

KERNEL_PATCH_SERIES=patches/series.gentoo-6.12
KERNEL_CONFIG_SERIES=configs/series.tabor
KERNEL_DTB_TARGETS="arch/powerpc/boot/dts/fsl/p1022ds_36b.dtb arch/powerpc/boot/dts/fsl/tabor-a1222.dtb"
KERNEL_UBOOT_IMAGE_TARGET=tabor-a1222
