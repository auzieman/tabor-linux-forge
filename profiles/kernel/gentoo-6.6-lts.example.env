PROFILE_NAME=gentoo-6.6-lts
KERNEL_SOURCE_KIND=tarball

# Set these to the Gentoo-matched source tarball you actually want to test.
# A conservative starting point is to mirror a Gentoo-supported 6.6 release,
# then layer genpatches and local Tabor patches separately.
KERNEL_TARBALL_URL=https://cdn.kernel.org/pub/linux/kernel/v6.x/linux-6.6.129.tar.xz
KERNEL_TARBALL_NAME=linux-6.6.129.tar.xz

KERNEL_PATCH_SERIES=patches/series.gentoo-6.6
KERNEL_CONFIG_SERIES=configs/series.tabor
KERNEL_DTB_TARGETS="arch/powerpc/boot/dts/fsl/p1022ds_36b.dtb arch/powerpc/boot/dts/fsl/tabor-a1222.dtb"
